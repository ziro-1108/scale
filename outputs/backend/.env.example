# MySQL example:
# DATABASE_URL=mysql+pymysql://scale_user:scale_password@mysql-host:3306/scale?charset=utf8mb4

# Local dev fallback:
DATABASE_URL=sqlite:///./scale_dev.db

APP_NAME=SCALE
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
STORAGE_DIR=./storage

# External measurement server templates. The worker replaces {task_id}.
MEASUREMENT_RESULT_URL=http://measurement-server.local/tasks/{task_id}
MEASUREMENT_IMAGE_URL=http://measurement-server.local/tasks/{task_id}/image
WORKER_POLL_INTERVAL_SECONDS=3
WORKER_BATCH_SIZE=50
WORKER_CONCURRENCY=10
